{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "T210 Connect",
  "version": "0.1.0",
  "identifier": "com.abtoolkit.t210-connect",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "T210 Connect",
        "width": 800,
        "height": 600,
        "minWidth": 500,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/favicon.ico"
    ]
  }
}
